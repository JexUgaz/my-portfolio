---
import ExpandIcon from "@/components/icons/ExpandIcon.astro";
import { Image } from "astro:assets";
interface Props {
  image: ImageMetadata;
  alt: string;
  popupKey: string;
  hasDetails: boolean;
}

const { alt, image, popupKey, hasDetails } = Astro.props;
---

<div class="relative rounded-t-xl shadow-md aspect-video overflow-hidden">
  <Image
    src={image}
    alt={alt}
    class="absolute inset-0 h-full w-auto object-cover transition-transform duration-300 ease-out group-hover:scale-105"
    width={500}
  />
  {
    hasDetails && (
      <button
        popovertarget={popupKey}
        class="absolute bottom-1 right-0 bg-primary/80 py-1 px-2 rounded-2xl text-sm flex gap-1 items-center justify-end
          transition-all duration-300 ease-in-out xl:translate-y-100 group-hover:translate-y-0"
      >
        More Details
        <ExpandIcon class="size-4" />
      </button>
    )
  }
</div>

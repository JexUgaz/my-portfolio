---
import type { ProjectStatus } from "@/types/Project";

interface Props {
  status: ProjectStatus;
}

const { status } = Astro.props;
---

<span
  class="absolute top-4 right-0 z-10 font-extrabold text-xs tracking-widest
         py-2 pl-4 pr-2 rounded-l-md shadow-md uppercase text-primary bg-white
         transition-all duration-300 ease-in-out xl:translate-x-100 group-hover:translate-x-0
         italic
         [clip-path:polygon(10px_0%,100%_0%,100%_100%,10px_100%,0%_50%)]"
>
  {status}
</span>
